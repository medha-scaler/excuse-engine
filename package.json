{
  "name": "excuse-engine",
  "version": "1.0.0",
  "description": "Event-driven Slack bot that transforms attendance updates into sarcastic analytics",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "backfill": "node src/scripts/backfill.js",
    "worker:dev": "wrangler dev worker/index.js",
    "worker:deploy": "wrangler deploy",
    "db:create": "wrangler d1 create office-police-db",
    "db:migrate": "wrangler d1 execute office-police-db --file=./worker/schema.sql"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@slack/bolt": "^3.19.0",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "wrangler": "^4.101.0"
  }
}
